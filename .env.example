# MishMesh.ai — Environment Variables Template
# Copy to .env.local and fill in real values
# See DEPLOY.md for full instructions

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key

# OpenAI (PLATFORM — embeddings only. Users bring their own keys for agent AI)
OPENAI_API_KEY=sk-proj-...

# X / Twitter Auth
TWITTER_CLIENT_ID=your_consumer_key
TWITTER_CLIENT_SECRET=your_consumer_secret

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_USERNAME=MishMeshAiBot
TELEGRAM_WEBHOOK_URL=https://mishmesh.ai/api/telegram/webhook

# Crypto / Base L2
NEXT_PUBLIC_PLATFORM_FEE_WALLET=0xYourPlatformFeeWallet
WALLET_ENCRYPTION_KEY=your-wallet-encryption-key
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_CHAIN_ID=8453

# App
# Marketing-only mode: when "true", middleware locks the site down to the
# marketing surface (/, /privacy, /terms, /support, /u/*, /b/*) and 302s
# every other route to /. Set to "false" (or remove) to restore the full app.
NEXT_PUBLIC_MARKETING_ONLY=false
NEXT_PUBLIC_APP_URL=https://mishmesh.ai
NEXTAUTH_URL=https://mishmesh.ai
NEXTAUTH_SECRET=run_openssl_rand_-base64_32

# Cron
CRON_SECRET=run_openssl_rand_-base64_32

# Email (optional)
# SENDGRID_API_KEY=SG...

NFT_CONTRACT_ADDRESS=
NEXT_PUBLIC_NFT_CONTRACT=

# ─── BLINK token + NFT contracts (Ethereum mainnet) ───
# Free key at alchemy.com → create an app on Ethereum Mainnet.
# Used SERVER-SIDE only to read public holdings via Alchemy SDK.
ALCHEMY_API_KEY=

# BLINK ERC-20 token. Mainnet canonical address.
NEXT_PUBLIC_BLINK_TOKEN_CONTRACT=0xe7BF94959b0bfa8CB9e61149de5BFb387B40761B
# Optional — overrides the Genesis collection if Phase 1 contract is replaced.
NEXT_PUBLIC_BLINK_GENESIS_CONTRACT=0x85e7CB56fA10f26fEAe20449e71AD1503867799A
# Set to the Mythics contract once minted. Holdings lookup tolerates a missing value.
NEXT_PUBLIC_BLINK_MYTHICS_CONTRACT=

# ─── On-chain claim (EIP-712 BlinkRewards voucher flow) ───
# Both must be set for /api/claim/voucher to activate; otherwise the claim
# page transparently falls back to the custodial transfer (DEPLOYER_PRIVATE_KEY).
# BlinkRewards contract on Ethereum mainnet (mints $BLINK against signed vouchers).
NEXT_PUBLIC_BLINK_REWARDS_CONTRACT=
# Private key of the authorized voucher signer for BlinkRewards. Server-only.
BLINK_SIGNER_PRIVATE_KEY=
# RPC endpoints — server-side (custodial sends, receipt checks) and client-side (wagmi).
ETH_RPC_URL=https://ethereum-rpc.publicnode.com
NEXT_PUBLIC_ETH_RPC_URL=https://ethereum-rpc.publicnode.com

# ─── BlinkWorld Airdrop Claim v3 (/claim) ───
# The claim page reads player codes/balances from the BLINKWORLD GAME project
# (lutlnwshbbhbwszpzxks) — a DIFFERENT Supabase project from the marketing site.
# Server-only; never expose in client bundles.
BLINKWORLD_SUPABASE_URL=https://lutlnwshbbhbwszpzxks.supabase.co
BLINKWORLD_SUPABASE_SERVICE_ROLE_KEY=
# Random 32+ chars — signs the httpOnly claim-session cookies (HMAC).
CLAIM_SESSION_SECRET=
# Long password for /claim/admin (falls back to ADMIN_PASSWORD if unset).
CLAIM_ADMIN_PASSWORD=

# ─── BlinkWorld Airdrop on-chain payout (BlinkPayoutVault) ───
# Auto-send on admin Approve. All server-only — never expose in client bundles.
# Deployed BlinkPayoutVault address (see blink-token/payout-vault, SHIP.md).
CLAIM_PAYOUT_VAULT_ADDRESS=
# Hot operator private key — the vault's payout()-only role. NOT the owner key.
CLAIM_PAYOUT_OPERATOR_KEY=
# BLINK tokens per Blink point (default 1 = 1:1).
CLAIM_PAYOUT_RATIO=1
# Per-player sanity cap in whole BLINK (server-side; vault also caps per-tx).
CLAIM_PAYOUT_MAX_TOKENS=1000000
# Optional RPC override for payout txs (falls back to ETH_RPC_URL).
# CLAIM_PAYOUT_RPC_URL=
